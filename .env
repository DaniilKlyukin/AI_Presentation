# =================================================================
# ГЛОБАЛЬНЫЕ НАСТРОЙКИ СЛАЙДА
# =================================================================
PPT_ASPECT_RATIO=16:9
PPT_TITTLE_MARGIN_CM=0.0
# Внутренние отступы контентного блока (слева и справа)
PPT_BODY_MARGIN_CM=1.0
# Индексы макетов (зависит от шаблона .pptx)
PPT_LAYOUT_TITLE_IDX=0
PPT_LAYOUT_CONTENT_IDX=1

# =================================================================
# ТИПОГРАФИКА И ОБЩИЕ ИНТЕРВАЛЫ
# =================================================================
PPT_FONT="Bookman Old Style"
PPT_BODY_SIZE=22
PPT_LINE_SPACING=1.15
PPT_BULLET_SPACING=0.0

# =================================================================
# ЗАГОЛОВОК СЛАЙДА (Title Bar)
# =================================================================
PPT_TITLE_HEIGHT_CM=1.2
PPT_TITLE_SIZE=28
# Фон плашки заголовка (RGB)
PPT_TITLE_BG_COLOR=235, 240, 248
# Цвет текста заголовка (RGB)
PPT_TITLE_FONT_COLOR=38, 70, 115

# =================================================================
# НИЖНИЙ КОЛОНТИТУЛ (Footer)
# =================================================================
PPT_FOOTER_TEXT="Клюкин Д.А."
PPT_FOOTER_HEIGHT_CM=1.2
PPT_FOOTER_FONT_SIZE=12
PPT_FOOTER_BORDER_COLOR=38,70,115

# =================================================================
# НУМЕРАЦИЯ СЛАЙДОВ
# =================================================================
PPT_SLIDE_NUMBERING=True
PPT_NUMBERING_WIDTH_CM=3
PPT_NUMBERING_FONT_SIZE=14

# =================================================================
# КОД, МАТЕМАТИКА, ТАБЛИЦЫ И ИЗОБРАЖЕНИЯ
# =================================================================
PPT_CODE_FONT="Courier New"
PPT_CODE_SIZE=20
# Нумерация выносных (блочных) формул
PPT_FORMULA_NUMBERING=True
PPT_IMAGE_WIDTH_RATIO=0.9
PPT_TABLE_ROW_HEIGHT_CM=1.0

# =================================================================
# РАЗМЕТКА, БУФЕРЫ И ОТСТУПЫ
# =================================================================
# Отступы и буферы (в дюймах или см)
PPT_CONTENT_BOTTOM_BUFFER_INCH=1.5
PPT_TITLE_SLIDE_TITLE_TOP_INCH=2.0
PPT_TITLE_SLIDE_SUBTITLE_TOP_INCH=4.0
PPT_TEXT_FRAME_PADDING_CM=0.13

# Общий отступ блока текста слева (в см)
PPT_TEXT_LEFT_INDENT_CM=0.0
# Отступ первой строки относительно левого края (в см)
# Если 0 — текста идет ровно. Если положительный — красная строка.
# Если отрицательный — выступ (hanging indent).
PPT_TEXT_FIRST_LINE_INDENT_CM=0.0